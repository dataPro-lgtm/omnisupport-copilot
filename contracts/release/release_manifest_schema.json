{
  "$schema": "https://json-schema.org/draft/2020-12",
  "$id": "omni://contracts/release/release_manifest/v1",
  "title": "ReleaseManifest",
  "description": "OmniSupport Copilot — 统一发布清单 v1。绑定数据版本、索引版本、Prompt 版本与评测结果，是回滚的唯一基准。",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "release_id", "schema_version", "env",
    "data_release_id", "index_release_id",
    "prompt_release_id", "eval_run_id",
    "git_sha", "created_at", "created_by", "status"
  ],
  "properties": {
    "release_id": {
      "type": "string",
      "description": "发布唯一 ID，格式: {env}-{YYYYMMDD}-{seq:03d}",
      "pattern": "^(dev|staging|prod)-[0-9]{8}-[0-9]{3}$"
    },
    "schema_version": {
      "type": "string",
      "const": "release_manifest_v1"
    },
    "env": {
      "type": "string",
      "enum": ["dev", "staging", "prod"]
    },
    "data_release_id": {
      "type": "string",
      "description": "数据层版本标识"
    },
    "index_release_id": {
      "type": "string",
      "description": "向量/倒排索引版本标识"
    },
    "prompt_release_id": {
      "type": "string",
      "description": "Prompt 模板版本标识"
    },
    "skill_release_id": {
      "type": ["string", "null"],
      "description": "Week09 Skill Pack 版本标识。为空表示该 release 尚未绑定 Skill Pack。"
    },
    "skills": {
      "type": "array",
      "description": "Skill Pack 依赖锁定列表，用于把数据、索引、Prompt、Skill、评测绑定为可回滚单元。",
      "items": {
        "type": "object",
        "required": ["name", "version", "digest"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "source": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "eval_run_id": {
      "type": "string",
      "description": "关联的评测运行 ID"
    },
    "eval_dataset": {
      "type": "object",
      "description": "Week11 评测集资产版本锁定。不同数据集版本会产生不同分数，必须进入 release manifest。",
      "required": ["id", "version", "sample_count", "categories", "digest"],
      "properties": {
        "id": {"type": "string"},
        "version": {"type": "string"},
        "sample_count": {"type": "integer", "minimum": 1},
        "categories": {
          "type": "object",
          "properties": {
            "happy": {"type": "integer", "minimum": 0},
            "boundary": {"type": "integer", "minimum": 0},
            "adversarial": {"type": "integer", "minimum": 0},
            "multi_hop": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        },
        "generated_from": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "count"],
            "properties": {
              "source": {"type": "string"},
              "count": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": false
          }
        },
        "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      },
      "additionalProperties": false
    },
    "judge_calibration": {
      "type": "object",
      "description": "LLM-as-Judge 校准报告快照。生产环境应随 judge prompt 一起锁版本。",
      "properties": {
        "judge_prompt_version": {"type": "string"},
        "calibration_set": {"type": "string"},
        "sample_count": {"type": "integer", "minimum": 0},
        "cohen_kappa": {"type": "number"},
        "pearson_r": {"type": "number"},
        "mae": {"type": "number", "minimum": 0},
        "top_k_overlap": {"type": "number", "minimum": 0, "maximum": 1},
        "trust_level": {"type": "string", "enum": ["high", "low"]}
      },
      "additionalProperties": false
    },
    "git_sha": {
      "type": "string",
      "description": "代码版本 git commit SHA",
      "pattern": "^[a-f0-9]{40}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "description": "发布者标识 (人员 ID 或 CI job ID)"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "active", "rolled_back", "deprecated"]
    },
    "previous_release_id": {
      "type": ["string", "null"],
      "description": "上一个活跃 release，用于快速回滚"
    },
    "eval_summary": {
      "type": "object",
      "description": "评测关键指标快照",
      "properties": {
        "faithfulness": {"type": "number"},
        "answer_relevance": {"type": "number"},
        "context_precision": {"type": "number"},
        "context_recall": {"type": "number"},
        "answer_correctness": {"type": "number"},
        "semantic_similarity": {"type": "number"},
        "retrieval_precision": {"type": "number"},
        "regression_pass_rate": {"type": "number"},
        "adversarial_pass_rate": {"type": "number"},
        "safety_pass_rate": {"type": "number"},
        "latency_p99_ms": {"type": "number"},
        "cost_per_query_usd": {"type": "number"},
        "total_cases": {"type": "integer"},
        "failed_cases": {"type": "integer"}
      }
    },
    "business_slo": {
      "type": "object",
      "description": "业务 SLO 与合规红线。Week11 用于把技术评测翻译成上线决策。",
      "required": ["domain", "metrics"],
      "properties": {
        "domain": {"type": "string"},
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["target", "current", "status"],
            "properties": {
              "target": {"type": ["number", "string"]},
              "current": {"type": "number"},
              "status": {"type": "string", "enum": ["pass", "fail"]}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "rollout": {
      "type": "object",
      "description": "灰度发布和自动回滚策略。",
      "properties": {
        "auto_rollback_on": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric", "threshold"],
            "properties": {
              "metric": {"type": "string"},
              "threshold": {"type": ["number", "string"]}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "rollout_notes": {
      "type": "string",
      "description": "发布说明"
    },
    "rollback_reason": {
      "type": ["string", "null"],
      "description": "若已回滚，记录原因"
    },
    "services": {
      "type": "object",
      "description": "各服务镜像版本",
      "properties": {
        "rag_api": {"type": "string"},
        "tool_api": {"type": "string"},
        "admin_api": {"type": "string"}
      }
    }
  },
  "additionalProperties": false
}
