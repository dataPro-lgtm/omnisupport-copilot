{
  "$schema": "https://json-schema.org/draft/2020-12",
  "$id": "omni://contracts/evals/eval_report/v1",
  "title": "EvalReport",
  "description": "Week11 evaluation report generated by evals/run_ragas.py.",
  "type": "object",
  "required": [
    "eval_run_id",
    "release_id",
    "eval_dataset_id",
    "eval_dataset_version",
    "eval_dataset_digest",
    "run_at",
    "total_cases",
    "passed_cases",
    "failed_cases",
    "category_breakdown",
    "metrics",
    "latency",
    "cost",
    "gate",
    "results"
  ],
  "properties": {
    "eval_run_id": {"type": "string"},
    "release_id": {"type": "string"},
    "eval_dataset_id": {"type": "string"},
    "eval_dataset_version": {"type": "string"},
    "eval_dataset_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "run_at": {"type": "string", "format": "date-time"},
    "total_cases": {"type": "integer", "minimum": 0},
    "passed_cases": {"type": "integer", "minimum": 0},
    "failed_cases": {"type": "integer", "minimum": 0},
    "category_breakdown": {"type": "object"},
    "metrics": {
      "type": "object",
      "required": [
        "faithfulness",
        "answer_relevance",
        "context_precision",
        "context_recall",
        "answer_correctness",
        "semantic_similarity",
        "pass_rate",
        "adversarial_pass_rate",
        "safety_pass_rate"
      ],
      "properties": {
        "faithfulness": {"type": "number", "minimum": 0, "maximum": 1},
        "answer_relevance": {"type": "number", "minimum": 0, "maximum": 1},
        "context_precision": {"type": "number", "minimum": 0, "maximum": 1},
        "context_recall": {"type": "number", "minimum": 0, "maximum": 1},
        "answer_correctness": {"type": "number", "minimum": 0, "maximum": 1},
        "semantic_similarity": {"type": "number", "minimum": 0, "maximum": 1},
        "pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "adversarial_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "safety_pass_rate": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": true
    },
    "latency": {
      "type": "object",
      "required": ["avg_ms", "p50_ms", "p99_ms"],
      "properties": {
        "avg_ms": {"type": "number", "minimum": 0},
        "p50_ms": {"type": "number", "minimum": 0},
        "p99_ms": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "cost": {
      "type": "object",
      "required": ["total_usd", "avg_per_query_usd"],
      "properties": {
        "total_usd": {"type": "number", "minimum": 0},
        "avg_per_query_usd": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "gate": {
      "type": "object",
      "required": ["status", "pass_rate", "adversarial_pass_rate", "blocking_reasons"],
      "properties": {
        "status": {"type": "string", "enum": ["pass", "fail"]},
        "pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "adversarial_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "blocking_reasons": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "results": {"type": "array"}
  },
  "additionalProperties": false
}
