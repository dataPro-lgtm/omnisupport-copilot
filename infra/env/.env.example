ANTHROPIC_API_KEY=

# PostgreSQL
POSTGRES_USER=omni
POSTGRES_PASSWORD=omnipass
POSTGRES_DB=omnisupport

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Release / seed
RELEASE_ID=dev-local
SEED_TICKET_COUNT=500

# Week04 Lakehouse / Iceberg
ICEBERG_CATALOG_NAME=omni
ICEBERG_CATALOG_TYPE=sql
ICEBERG_CATALOG_URI=postgresql+psycopg2://omni:omnipass@postgres:5432/omnisupport
ICEBERG_WAREHOUSE=s3://omni-lakehouse/warehouse
ICEBERG_NAMESPACE_BRONZE=bronze
ICEBERG_NAMESPACE_SILVER=silver
ICEBERG_FILE_IO=pyiceberg.io.pyarrow.PyArrowFileIO

# S3-compatible MinIO for PyIceberg FileIO
ICEBERG_S3_ENDPOINT=http://minio:9000
ICEBERG_S3_ACCESS_KEY_ID=minioadmin
ICEBERG_S3_SECRET_ACCESS_KEY=minioadmin
ICEBERG_S3_REGION=us-east-1
ICEBERG_S3_PATH_STYLE_ACCESS=true

# Week04 run metadata
WEEK04_DATA_RELEASE_ID=week04-dev-local
WEEK04_INGEST_BATCH_ID=week04-smoke
WEEK04_REPORT_DIR=reports/week04
